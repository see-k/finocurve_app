# @release-it/conventional-changelog@10 still declares peer release-it@^18||^19;
# we use release-it@20. npm treats that as a peer conflict until the plugin ships
# a compatible release. legacy-peer-deps only relaxes peer resolution (not semver
# ranges for direct deps). Revisit after https://github.com/release-it/conventional-changelog updates.
legacy-peer-deps=true
