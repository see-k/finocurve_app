{
  "name": "finocurve-app",
  "version": "1.3.0",
  "description": "FinoCurve Desktop - Modern Investment Banking",
  "author": "finocurve llc",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "ci": "npm ci --legacy-peer-deps",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --mac",
    "dist:arm": "npm run build && electron-builder --mac --arm64",
    "dist:intel": "npm run build && electron-builder --mac --x64",
    "dist:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "dist:win:x64": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64",
    "dist:win:arm64": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --arm64",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "build": {
    "appId": "com.finocurve.app",
    "productName": "FinoCurve",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/images/finocurve-logo-512.png",
      "category": "public.app-category.finance"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "public/images/finocurve.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@langchain/aws": "^1.3.7",
    "@langchain/core": "^1.1.45",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vnedyalk0v/react19-simple-maps": "^2.0.7",
    "better-sqlite3": "^12.9.0",
    "country-list": "^2.4.1",
    "html-to-text": "^10.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "react-select": "^5.10.2",
    "react-tooltip": "^6.0.2",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "yahoo-finance2": "^3.14.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/country-list": "^2.1.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.9.1",
    "esbuild": "^0.28.0",
    "png-to-ico": "^3.0.1",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.12",
    "lodash": "4.18.1",
    "path-to-regexp": "8.4.2",
    "cosmiconfig": {
      "yaml": "1.10.3"
    }
  }
}
