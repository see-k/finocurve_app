{
  "name": "finocurve-app",
  "version": "1.0.0",
  "description": "FinoCurve Desktop - Modern Investment Banking",
  "author": "finocurve llc",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --mac",
    "dist:arm": "npm run build && electron-builder --mac --arm64",
    "dist:intel": "npm run build && electron-builder --mac --x64"
  },
  "build": {
    "appId": "com.finocurve.app",
    "productName": "FinoCurve",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/images/finocurve-logo-512.png",
      "category": "public.app-category.finance"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.991.0",
    "@aws-sdk/s3-request-presigner": "^3.991.0",
    "@langchain/aws": "^1.2.3",
    "@langchain/core": "^1.1.25",
    "@langchain/ollama": "^1.2.2",
    "@langchain/openai": "^1.2.8",
    "@vnedyalk0v/react19-simple-maps": "^2.0.2",
    "country-list": "^2.4.1",
    "dotenv": "^17.3.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.469.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "react-select": "^5.10.2",
    "react-tooltip": "^5.30.0",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "yahoo-finance2": "^3.13.0"
  },
  "devDependencies": {
    "@types/country-list": "^2.1.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
